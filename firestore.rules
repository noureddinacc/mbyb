rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Dynamic Admin Check: Checks if user is the master admin OR is listed as an admin for their university
    function isAdmin() {
      let isMasterAdmin = request.auth.token.email == 'solosoulacc@tutamail.com';
      // Use getAfter for writes if necessary, but here we just need to be careful with nulls
      let userDoc = get(/databases/$(database)/documents/Users/$(request.auth.uid));
      
      return isAuthenticated() && (
        isMasterAdmin || 
        (userDoc != null && 
         userDoc.data != null && 
         userDoc.data.get('universityId', '') != '' &&
         request.auth.token.email in get(/databases/$(database)/documents/Universities/$(userDoc.data.universityId)).data.adminEmails)
      );
    }

    // Helper function to check if user is NOT blocked
    function isNotBlocked() {
      let userDoc = get(/databases/$(database)/documents/Users/$(request.auth.uid));
      return isAuthenticated() && (
        request.auth.token.email == 'solosoulacc@tutamail.com' || // Fast path for master admin
        userDoc == null || // Allow if profile doesn't exist yet (signup flow)
        userDoc.data == null ||
        userDoc.data.get('isBlocked', false) == false
      );
    }

    // 1. Universities collection (Public Read for Signup)
    match /Universities/{uniId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'solosoulacc@tutamail.com';
    }

    // 2. Users collection
    match /Users/{userId} {
      allow read: if isAuthenticated();
      // Only check isAdmin if the user is NOT editing their own profile to avoid circularity
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    // 3. Books collection
    match /books/{bookId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isNotBlocked() && request.resource.data.publisherId == request.auth.uid;
      allow update, delete: if isAuthenticated() && (
        (request.auth.uid == resource.data.publisherId && isNotBlocked()) ||
        isAdmin()
      );
    }

    // 4. Requests collection
    match /requests/{requestId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.requesterId ||
        request.auth.uid == resource.data.publisherId ||
        isAdmin()
      );
      allow create: if isAuthenticated() && isNotBlocked() && request.resource.data.requesterId == request.auth.uid;
      allow update, delete: if isAuthenticated() && (
        (request.auth.uid == resource.data.requesterId && isNotBlocked()) ||
        (request.auth.uid == resource.data.publisherId && isNotBlocked()) ||
        isAdmin()
      );
    }

    // 5. Chats collection
    match /chats/{chatId} {
      allow read: if isAuthenticated() && (
        request.auth.uid in resource.data.participantIds ||
        isAdmin()
      );
      allow create: if isAuthenticated() && isNotBlocked() && request.resource.data.participantIds.hasAny([request.auth.uid]);
      allow update: if isAuthenticated() && (
        (request.auth.uid in resource.data.participantIds && isNotBlocked()) ||
        isAdmin()
      );
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && (
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds ||
          isAdmin()
        );
        allow create: if isAuthenticated() && isNotBlocked() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds &&
          request.resource.data.senderId == request.auth.uid;
      }
    }

    // 6. Reports collection
    match /reports/{reportId} {
      allow create: if isAuthenticated() && request.resource.data.reporterId == request.auth.uid;
      allow read, delete: if isAdmin();
    }

    // 7. System Messages
    match /system_messages/{messageId} {
      allow read, write: if isAdmin();
      allow read, delete: if isAuthenticated() && resource.data.recipientId == request.auth.uid;
      allow update: if isAuthenticated() && 
                    resource.data.recipientId == request.auth.uid &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
    }
  }
}
