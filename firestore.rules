rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Robust Admin Check
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'solosoulacc@tutamail.com' ||
        (exists(/databases/$(database)/documents/Users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/Users/$(request.auth.uid)).data.email == 'solosoulacc@tutamail.com')
      );
    }

    // Helper function to check if user is NOT blocked
    function isNotBlocked() {
      return isAuthenticated() && (
        isAdmin() ||
        !exists(/databases/$(database)/documents/Users/$(request.auth.uid)) || 
        get(/databases/$(database)/documents/Users/$(request.auth.uid)).data.get('isBlocked', false) == false
      );
    }

    // Users collection
    match /Users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    // Books collection
    match /books/{bookId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isNotBlocked();
      allow update, delete: if isAuthenticated() && (
        (request.auth.uid == resource.data.publisherId && isNotBlocked()) ||
        isAdmin()
      );
    }

    // Requests collection
    match /requests/{requestId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.requesterId ||
        request.auth.uid == resource.data.publisherId ||
        isAdmin()
      );
      allow create: if isAuthenticated() && isNotBlocked();
      allow update, delete: if isAuthenticated() && (
        (request.auth.uid == resource.data.requesterId && isNotBlocked()) ||
        (request.auth.uid == resource.data.publisherId && isNotBlocked()) ||
        isAdmin()
      );
    }

    // Chats collection
    match /chats/{chatId} {
      allow read: if isAuthenticated() && (
        request.auth.uid in resource.data.participantIds ||
        isAdmin()
      );
      allow create: if isAuthenticated() && isNotBlocked();
      allow update: if isAuthenticated() && (
        (request.auth.uid in resource.data.participantIds && isNotBlocked()) ||
        isAdmin()
      );
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && (
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds ||
          isAdmin()
        );
        allow create: if isAuthenticated() && isNotBlocked() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds;
      }
    }

    // Reports collection
    match /reports/{reportId} {
      // Prevent reporting the admin
      allow create: if isAuthenticated() && (
        (request.resource.data.targetType == 'user' && get(/databases/$(database)/documents/Users/$(request.resource.data.targetId)).data.email != 'solosoulacc@tutamail.com') ||
        (request.resource.data.targetType == 'book' && get(/databases/$(database)/documents/books/$(request.resource.data.targetId)).data.get('publisherEmail', '') != 'solosoulacc@tutamail.com') ||
        (request.resource.data.targetType != 'user' && request.resource.data.targetType != 'book')
      );
      allow read, delete: if isAdmin();
    }

    // System Messages (Admin to User)
    match /system_messages/{messageId} {
      allow read, write: if isAdmin();
      allow read: if isAuthenticated() && resource.data.recipientId == request.auth.uid;
      allow update: if isAuthenticated() && 
                    resource.data.recipientId == request.auth.uid &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
    }
  }
}
